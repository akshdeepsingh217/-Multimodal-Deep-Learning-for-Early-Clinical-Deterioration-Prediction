import pandas as pd
import numpy as np
import seaborn as sns
import matplotlib.pyplot as plt
import os
import logging
from sqlalchemy import create_engine

# Set up professional logging for GitHub execution
logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')

def get_db_connection():
    """
    Establishes a connection to the local PostgreSQL MIMIC-IV database.
    (Requires environment variables or updated credentials to match your local setup).
    """
    logging.info("Connecting to PostgreSQL MIMIC-IV database...")
    DB_USER = os.getenv('DB_USER', 'postgres')
    DB_PASSWORD = os.getenv('DB_PASSWORD', 'password') # Update to your PGAdmin password
    DB_HOST = os.getenv('DB_HOST', 'localhost')
    DB_PORT = os.getenv('DB_PORT', '5432')
    DB_NAME = os.getenv('DB_NAME', 'mimiciv')
    
    engine_url = f"postgresql://{DB_USER}:{DB_PASSWORD}@{DB_HOST}:{DB_PORT}/{DB_NAME}"
    return create_engine(engine_url)

def extract_mimic_data(engine):
    """
    Task 3.1: Extracts structured vitals and unstructured notes from the PostgreSQL schema.
    """
    logging.info("Extracting structured vitals (chartevents)...")
    # Using specific itemids for Heart Rate (220045), Mean BP (220181), and SpO2 (220277)
    vitals_query = """
        SELECT subject_id, hadm_id, charttime, itemid, valuenum
        FROM mimiciv_icu.chartevents
        WHERE itemid IN (220045, 220181, 220277)
        AND valuenum IS NOT NULL;
    """
    vitals_df = pd.read_sql_query(vitals_query, engine)
    vitals_df['charttime'] = pd.to_datetime(vitals_df['charttime'])
    
    logging.info("Extracting unstructured clinical notes (mimic_iv_note)...")
    notes_query = """
        SELECT subject_id, hadm_id, charttime, note_type, text
        FROM mimiciv_note.note
        WHERE note_type IN ('Nursing/other', 'Discharge summary');
    """
    notes_df = pd.read_sql_query(notes_query, engine)
    
    return vitals_df, notes_df

def engineer_time_deltas(vitals_df):
    """
    Task 3.2: Engineering synthetic time-delta features (Δt) to model asynchronous timestamps.
    """
    logging.info("Engineering Time-Delta (Δt) features...")
    
    # Mapping itemids to readable names
    vital_ids = {220045: 'HeartRate', 220181: 'MeanBP', 220277: 'SpO2'}
    vitals_df['Vital_Name'] = vitals_df['itemid'].map(vital_ids)
    
    # Sorting chronologically per patient admission to calculate elapsed time
    vitals_df = vitals_df.sort_values(by=['hadm_id', 'itemid', 'charttime'])
    vitals_df['prev_time'] = vitals_df.groupby(['hadm_id', 'itemid'])['charttime'].shift(1)
    
    # Calculating difference in hours
    vitals_df['time_delta_hours'] = (vitals_df['charttime'] - vitals_df['prev_time']).dt.total_seconds() / 3600.0
    vitals_df['time_delta_hours'] = vitals_df['time_delta_hours'].fillna(0) # First measurement gets 0
    
    return vitals_df

def generate_eda_visualizations(vitals_df):
    """
    Task 3.2: Execute Exploratory Data Analysis (EDA) and save visualizations for the report.
    """
    logging.info("Generating EDA Visualizations...")
    os.makedirs("output_plots", exist_ok=True)
    
    # Pivoting data for correlation calculations
    pivot_df = vitals_df.pivot_table(index=['hadm_id', 'charttime'], columns='Vital_Name', values='valuenum').reset_index()
    
    # 1. Generating Correlation Heatmap
    plt.figure(figsize=(8, 6))
    corr_matrix = pivot_df[['HeartRate', 'MeanBP', 'SpO2']].corr()
    sns.heatmap(corr_matrix, annot=True, cmap='coolwarm', vmin=-1, vmax=1, fmt=".2f", linewidths=.5)
    plt.title('Correlation Matrix of ICU Vital Signs (Full MIMIC-IV)', pad=20)
    plt.tight_layout()
    plt.savefig("output_plots/vital_correlations.png", dpi=300)
    plt.close()

    # 2. Generating Time-Delta Distribution Histogram
    plt.figure(figsize=(10, 5))
    # Filtering out initial 0s and outliers (>24 hours) for a clean distribution shape
    plot_data = vitals_df[(vitals_df['time_delta_hours'] > 0) & (vitals_df['time_delta_hours'] < 24)]
    sns.histplot(plot_data['time_delta_hours'], bins=50, kde=True, color='indigo')
    plt.title('Distribution of Time Between Measurements (Asynchronous Sampling)', pad=15)
    plt.xlabel('Hours Since Last Measurement (Δt)')
    plt.ylabel('Frequency')
    plt.tight_layout()
    plt.savefig("output_plots/time_delta_distribution.png", dpi=300)
    plt.close()

if __name__ == "__main__":
    # 1. Establishing connection to the full database
    engine = get_db_connection()
    
    # 2. Extracting Data
    vitals_df, notes_df = extract_mimic_data(engine)
    
    # 3. Engineering Features
    processed_vitals = engineer_time_deltas(vitals_df)
    
    # 4. Generating Visuals
    generate_eda_visualizations(processed_vitals)
    
    # 5. Saving processed data arrays to disk for future usage.
    logging.info("Saving engineered data arrays for baseline modeling...")
    os.makedirs("processed_data", exist_ok=True)
    processed_vitals.to_csv("processed_data/engineered_vitals.csv", index=False)
    notes_df.to_csv("processed_data/extracted_notes.csv", index=False)
    
    logging.info("EDA and Feature Engineering Pipeline Complete! Visuals saved to 'output_plots/' directory.")
